<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="mobil.Popups.ForgotPasswordPopup">

    <VerticalStackLayout Padding="25" WidthRequest="300" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" Spacing="15">
        <Label Text="Forgot Password" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center"/>
        <Entry Placeholder="Email" Text="{Binding Email}" />
        <Label Text="{Binding ErrorMessage}" TextColor="{AppThemeBinding Light=Red, Dark=#FF6B6B}"/>
        <Button Text="Send" Command="{Binding SendCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" BackgroundColor="#1173d4" TextColor="White" FontAttributes="Bold" />
        <Button Text="Cancel" Command="{Binding CloseCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" BackgroundColor="#1173d4" TextColor="White" FontAttributes="Bold" />
        <ActivityIndicator IsVisible="{Binding IsBusy}" IsRunning="{Binding IsBusy}" Color="#2563EB" HeightRequest="30"/>
    </VerticalStackLayout>
</toolkit:Popup>
