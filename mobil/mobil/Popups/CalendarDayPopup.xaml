<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="mobil.Popups.CalendarDayPopup">

    <Border StrokeShape="RoundRectangle 16" Stroke="{AppThemeBinding Light=#e2e8f0, Dark=#2E2E2E}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" Padding="0" WidthRequest="340" MaximumHeightRequest="550">
        <Grid RowDefinitions="Auto, *, Auto">

            <!-- Header -->
            <Border Grid.Row="0" BackgroundColor="#1173d4" StrokeThickness="0" StrokeShape="RoundRectangle 16,16,0,0" Padding="20,16">
                <Grid ColumnDefinitions="*, Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="{Binding SelectedDate, StringFormat='{}{0:dddd}'}" FontSize="13" TextColor="#B3D4FC" />
                        <Label Text="{Binding SelectedDate, StringFormat='{}{0:yyyy. MMMM dd.}'}" FontSize="20" FontAttributes="Bold" TextColor="White" />
                    </VerticalStackLayout>
                    <Border Grid.Column="1" WidthRequest="36" HeightRequest="36" StrokeShape="RoundRectangle 18" BackgroundColor="{AppThemeBinding Light=#fefce8, Dark=#2A2A0D}" StrokeThickness="0" VerticalOptions="Center">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CloseCommand}" />
                        </Border.GestureRecognizers>
                        <Label Text="&#xf073;" FontFamily="FontAwesomeSolid" FontSize="16" TextColor="#a16207" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollView Grid.Row="1" Padding="16,12">
                <VerticalStackLayout Spacing="12">

                    <!-- Events list -->
                    <Label Text="EVENTS" FontSize="11" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#94a3b8, Dark=#666666}" IsVisible="{Binding DayEvents.Count, Converter={StaticResource IsNotZeroConverter}}" />
                    <CollectionView ItemsSource="{Binding DayEvents}" SelectionMode="None">
                        <CollectionView.EmptyView>
                            <VerticalStackLayout Spacing="8" Padding="0,10" HorizontalOptions="Center">
                                <Label Text="&#xf073;" FontFamily="FontAwesomeSolid" FontSize="28" TextColor="{AppThemeBinding Light=#cbd5e1, Dark=#444444}" HorizontalOptions="Center" />
                                <Label Text="No events for this day" FontSize="13" TextColor="{AppThemeBinding Light=#94a3b8, Dark=#666666}" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8" Padding="12" BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#262626}" StrokeShape="RoundRectangle 10" Stroke="{AppThemeBinding Light=#e2e8f0, Dark=#2E2E2E}" StrokeThickness="1">
                                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">
                                        <!-- Time badge -->
                                        <Border Grid.Column="0" WidthRequest="44" HeightRequest="44" StrokeShape="RoundRectangle 10" BackgroundColor="{AppThemeBinding Light=#F0F7FF, Dark=#0D2440}" StrokeThickness="0" VerticalOptions="Center">
                                            <Label Text="&#xf017;" FontFamily="FontAwesomeSolid" FontSize="18" TextColor="#1173d4" HorizontalOptions="Center" VerticalOptions="Center" />
                                        </Border>
                                        <!-- Event info -->
                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                            <Label Text="{Binding Title}" FontSize="14" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#E8E8E8}" LineBreakMode="TailTruncation" />
                                            <Label Text="{Binding StartAt, StringFormat='{}{0:HH:mm}'}" FontSize="11" TextColor="{AppThemeBinding Light=#64748b, Dark=#8E8E8E}" />
                                            <Label Text="{Binding Description}" FontSize="11" TextColor="{AppThemeBinding Light=#94a3b8, Dark=#666666}" LineBreakMode="TailTruncation" MaxLines="1" />
                                        </VerticalStackLayout>
                                        <!-- Delete button -->
                                        <Border Grid.Column="2" WidthRequest="32" HeightRequest="32" StrokeShape="RoundRectangle 16" BackgroundColor="{AppThemeBinding Light=#fef2f2, Dark=#2A1A1A}" StrokeThickness="0" VerticalOptions="Center">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.DeleteEventCommand}" CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>
                                            <Label Text="&#xf1f8;" FontFamily="FontAwesomeSolid" FontSize="13" TextColor="{AppThemeBinding Light=#DC2626, Dark=#FF6B6B}" HorizontalOptions="Center" VerticalOptions="Center" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <!-- Error -->
                    <Label Text="{Binding FormError}" TextColor="{AppThemeBinding Light=#DC2626, Dark=#FF6B6B}" FontSize="12" LineBreakMode="WordWrap" IsVisible="{Binding FormError, Converter={StaticResource IsNotNullConverter}}" />

                    <!-- New event form (toggleable) -->
                    <VerticalStackLayout Spacing="10" IsVisible="{Binding ShowForm}">
                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#f1f5f9, Dark=#2E2E2E}" />
                        <Label Text="NEW EVENT" FontSize="11" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#94a3b8, Dark=#666666}" />

                        <!-- Title -->
                        <Border StrokeShape="RoundRectangle 10" Stroke="{AppThemeBinding Light=#e2e8f0, Dark=#2E2E2E}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#262626}" Padding="12,0">
                            <Entry Placeholder="Event title" Text="{Binding TitleInput}" FontSize="14" TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#E8E8E8}" />
                        </Border>

                        <!-- Description -->
                        <Border StrokeShape="RoundRectangle 10" Stroke="{AppThemeBinding Light=#e2e8f0, Dark=#2E2E2E}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#262626}" Padding="12,0">
                            <Entry Placeholder="Description (optional)" Text="{Binding DescriptionInput}" FontSize="14" TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#E8E8E8}" />
                        </Border>

                        <!-- Time pickers -->
                        <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="Start" FontSize="11" TextColor="{AppThemeBinding Light=#64748b, Dark=#8E8E8E}" />
                                <Border StrokeShape="RoundRectangle 10" Stroke="{AppThemeBinding Light=#e2e8f0, Dark=#2E2E2E}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#262626}" Padding="8,0">
                                    <TimePicker Time="{Binding StartTime}" FontSize="14" TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#E8E8E8}" />
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="End" FontSize="11" TextColor="{AppThemeBinding Light=#64748b, Dark=#8E8E8E}" />
                                <Border StrokeShape="RoundRectangle 10" Stroke="{AppThemeBinding Light=#e2e8f0, Dark=#2E2E2E}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#262626}" Padding="8,0">
                                    <TimePicker Time="{Binding EndTime}" FontSize="14" TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#E8E8E8}" />
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Error -->
                        <Label Text="{Binding FormError}" TextColor="{AppThemeBinding Light=#DC2626, Dark=#FF6B6B}" FontSize="12" LineBreakMode="WordWrap" IsVisible="{Binding FormError, Converter={StaticResource IsNotNullConverter}}" />

                        <!-- Create button -->
                        <Button Text="Create Event" Command="{Binding CreateEventCommand}" BackgroundColor="#1173d4" TextColor="White" FontAttributes="Bold" CornerRadius="10" HeightRequest="44" FontSize="14" IsEnabled="{Binding IsCreating, Converter={StaticResource InverseBooleanConverter}}" />
                        <ActivityIndicator IsRunning="{Binding IsCreating}" IsVisible="{Binding IsCreating}" Color="#1173d4" HeightRequest="20" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </ScrollView>

            <!-- Footer: Add event toggle button -->
            <Border Grid.Row="2" Padding="16,12" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" StrokeThickness="0" StrokeShape="RoundRectangle 0,0,16,16">
                <Button Command="{Binding ToggleFormCommand}" BackgroundColor="{Binding ShowForm, Converter={StaticResource BoolToColorConverter}}" TextColor="{Binding ShowForm, Converter={StaticResource BoolToTextColorConverter}}" FontAttributes="Bold" CornerRadius="10" HeightRequest="44" FontSize="14">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding ShowForm}" Value="True">
                            <Setter Property="Text" Value="Cancel" />
                        </DataTrigger>
                        <DataTrigger TargetType="Button" Binding="{Binding ShowForm}" Value="False">
                            <Setter Property="Text" Value="+ Add Event" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </Border>
        </Grid>
    </Border>
</toolkit:Popup>
