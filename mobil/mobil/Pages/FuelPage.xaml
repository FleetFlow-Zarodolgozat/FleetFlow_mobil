<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:mobil.Pages.Components"
             xmlns:vm="clr-namespace:mobil.ViewModels"
             xmlns:models="clr-namespace:mobil.Models"
             x:Class="mobil.Pages.FuelPage"
             x:DataType="vm:FuelViewModel"
             Shell.NavBarIsVisible="False" BackgroundColor="{AppThemeBinding Light=#F6F7F8, Dark=#121212}">

    <Grid RowDefinitions="Auto, *, Auto">

        <!-- Top bar -->
        <Border Grid.Row="0" Padding="15" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" StrokeShape="Rectangle" StrokeThickness="0">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <Label Grid.Column="0" Text="&#xf52f;" FontFamily="FontAwesomeSolid" FontSize="20" TextColor="#EA580C" VerticalOptions="Center" />
                <Label Grid.Column="1" Text="Fuel Logs" FontAttributes="Bold" FontSize="18" TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#E8E8E8}" VerticalOptions="Center" Margin="10,0,0,0" />
                <Border Grid.Column="2" StrokeShape="RoundRectangle 10" StrokeThickness="0" BackgroundColor="#EA580C" Padding="14,8">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleNewCommand}" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="6">
                        <Label Text="&#xf067;" FontFamily="FontAwesomeSolid" FontSize="12" TextColor="White" VerticalOptions="Center" />
                        <Label Text="New" FontSize="13" FontAttributes="Bold" TextColor="White" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>
            </Grid>
        </Border>

        <!-- Scrollable content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="16">

                <!-- Loading -->
                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="#EA580C" HeightRequest="40" />

                <!-- Error -->
                <Border IsVisible="{Binding HasError}" BackgroundColor="{AppThemeBinding Light=#FEE2E2, Dark=#2A1A1A}" Stroke="{AppThemeBinding Light=#EF4444, Dark=#6B2020}" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="12">
                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="&#xf06a;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="{AppThemeBinding Light=#DC2626, Dark=#FF6B6B}" VerticalOptions="Start" />
                        <Label Grid.Column="1" Text="{Binding ErrorMessage}" TextColor="{AppThemeBinding Light=#DC2626, Dark=#FF6B6B}" FontSize="13" LineBreakMode="WordWrap" />
                    </Grid>
                </Border>

                <!-- Success -->
                <Border IsVisible="{Binding HasSuccess}" BackgroundColor="{AppThemeBinding Light=#D1FAE5, Dark=#1A2A1E}" Stroke="{AppThemeBinding Light=#10B981, Dark=#1B5E3A}" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="12">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="&#xf058;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="{AppThemeBinding Light=#059669, Dark=#4ADE80}" VerticalOptions="Center" />
                        <Label Text="{Binding SuccessMessage}" TextColor="{AppThemeBinding Light=#059669, Dark=#4ADE80}" FontSize="13" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!-- New Fuel Form -->
                <Border IsVisible="{Binding IsNewFuel}" StrokeShape="RoundRectangle 14" Stroke="#EA580C" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" Padding="16">
                    <VerticalStackLayout Spacing="14">
                        <!-- Header -->
                        <HorizontalStackLayout Spacing="8">
                            <Border WidthRequest="36" HeightRequest="36" StrokeShape="RoundRectangle 18" BackgroundColor="{AppThemeBinding Light=#FFF5E5, Dark=#2A1E0D}" StrokeThickness="0">
                                <Label Text="&#xf52f;" FontFamily="FontAwesomeSolid" FontSize="16" TextColor="#EA580C" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Text="New Fuel Log" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#E8E8E8}" VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#f1f5f9, Dark=#2E2E2E}" />

                        <!-- Date + Time -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Date &amp; Time" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#374151, Dark=#B0B0B0}" />
                            <Grid ColumnDefinitions="*, *" ColumnSpacing="8">
                                <Border Grid.Column="0" StrokeShape="RoundRectangle 8" Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#3A3A3A}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#262626}" Padding="10,4">
                                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="6">
                                        <Label Text="&#xf073;" FontFamily="FontAwesomeSolid" FontSize="13" TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#666666}" VerticalOptions="Center" />
                                        <DatePicker Grid.Column="1" Date="{Binding NewFuelDate}" Format="yyyy.MM.dd" TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#E8E8E8}" BackgroundColor="Transparent" FontSize="13" />
                                    </Grid>
                                </Border>
                                <Border Grid.Column="1" StrokeShape="RoundRectangle 8" Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#3A3A3A}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#262626}" Padding="10,4">
                                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="6">
                                        <Label Text="&#xf017;" FontFamily="FontAwesomeSolid" FontSize="13" TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#666666}" VerticalOptions="Center" />
                                        <TimePicker Grid.Column="1" Time="{Binding NewFuelTime}" TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#E8E8E8}" BackgroundColor="Transparent" FontSize="13" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </VerticalStackLayout>

                        <!-- Liters + Total Cost -->
                        <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0" Spacing="5">
                                <Label Text="Liters" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#374151, Dark=#B0B0B0}" />
                                <Border StrokeShape="RoundRectangle 8" Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#3A3A3A}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#262626}" Padding="12,8">
                                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="8">
                                        <Label Text="&#xf043;" FontFamily="FontAwesomeSolid" FontSize="13" TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#666666}" VerticalOptions="Center" />
                                        <Entry Grid.Column="1" Text="{Binding NewFuel.Liters}" Keyboard="Numeric" Placeholder="0.00" BackgroundColor="Transparent" FontSize="13" />
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="5">
                                <Label Text="Total Cost (Ft)" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#374151, Dark=#B0B0B0}" />
                                <Border StrokeShape="RoundRectangle 8" Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#3A3A3A}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#262626}" Padding="12,8">
                                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="8">
                                        <Label Text="&#xf155;" FontFamily="FontAwesomeSolid" FontSize="13" TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#666666}" VerticalOptions="Center" />
                                        <Entry Grid.Column="1" Text="{Binding NewFuel.TotalCost}" Keyboard="Numeric" Placeholder="0.00" BackgroundColor="Transparent" FontSize="13" />
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Odometer -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Odometer (km)" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#374151, Dark=#B0B0B0}" />
                            <Border StrokeShape="RoundRectangle 8" Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#3A3A3A}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#262626}" Padding="12,8">
                                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                                    <Label Text="&#xf018;" FontFamily="FontAwesomeSolid" FontSize="13" TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#666666}" VerticalOptions="Center" />
                                    <Entry Grid.Column="1" Text="{Binding NewFuel.OdometerKm}" Keyboard="Numeric" Placeholder="0" BackgroundColor="Transparent" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Station Name -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Station Name (optional)" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#374151, Dark=#B0B0B0}" />
                            <Border StrokeShape="RoundRectangle 8" Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#3A3A3A}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#262626}" Padding="12,8">
                                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                                    <Label Text="&#xf5e4;" FontFamily="FontAwesomeSolid" FontSize="13" TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#666666}" VerticalOptions="Center" />
                                    <Entry Grid.Column="1" Text="{Binding NewFuel.StationName}" Placeholder="e.g. OMV Budapest" BackgroundColor="Transparent" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Location -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Location (optional)" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#374151, Dark=#B0B0B0}" />
                            <Border StrokeShape="RoundRectangle 8" Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#3A3A3A}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#262626}" Padding="12,8">
                                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                                    <Label Text="&#xf3c5;" FontFamily="FontAwesomeSolid" FontSize="13" TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#666666}" VerticalOptions="Center" />
                                    <Entry Grid.Column="1" Text="{Binding NewFuel.LocationText}" Placeholder="e.g. M1 highway" BackgroundColor="Transparent" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Receipt Photo -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Receipt Photo" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#374151, Dark=#B0B0B0}" />
                            <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                                <Border Grid.Column="0" StrokeShape="RoundRectangle 10" Stroke="{AppThemeBinding Light=#e2e8f0, Dark=#2E2E2E}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#FFF5E5, Dark=#2A1E0D}" Padding="12">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding PickPhotoCommand}" />
                                    </Border.GestureRecognizers>
                                    <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                                        <Label Text="&#xf03e;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="#EA580C" VerticalOptions="Center" />
                                        <Label Text="Gallery" FontSize="13" FontAttributes="Bold" TextColor="#EA580C" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </Border>
                                <Border Grid.Column="1" StrokeShape="RoundRectangle 10" Stroke="{AppThemeBinding Light=#e2e8f0, Dark=#2E2E2E}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#FFF5E5, Dark=#2A1E0D}" Padding="12">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding TakePhotoCommand}" />
                                    </Border.GestureRecognizers>
                                    <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                                        <Label Text="&#xf030;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="#EA580C" VerticalOptions="Center" />
                                        <Label Text="Camera" FontSize="13" FontAttributes="Bold" TextColor="#EA580C" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </Border>
                            </Grid>

                            <!-- Photo preview -->
                            <Border IsVisible="{Binding HasNewPhoto}" StrokeShape="RoundRectangle 10" Stroke="#22c55e" StrokeThickness="2" BackgroundColor="{AppThemeBinding Light=#f0fdf4, Dark=#1A2A1E}" Padding="6">
                                <VerticalStackLayout Spacing="6">
                                    <Image Source="{Binding PreviewImage}" HeightRequest="160" Aspect="AspectFit" />
                                    <Label Text="&#xf058; Receipt photo selected" FontFamily="FontAwesomeSolid" TextColor="{AppThemeBinding Light=#22c55e, Dark=#4ADE80}" FontSize="12" HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Buttons -->
                        <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                            <Button Grid.Column="0" Text="Cancel" BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#2E2E2E}" TextColor="{AppThemeBinding Light=#374151, Dark=#B0B0B0}" FontAttributes="Bold" FontSize="14" CornerRadius="10" HeightRequest="45" Command="{Binding ToggleNewCommand}" />
                            <Button Grid.Column="1" Text="Create Log" BackgroundColor="#EA580C" TextColor="White" FontAttributes="Bold" FontSize="14" CornerRadius="10" HeightRequest="45"
                                    Command="{Binding CreateFuelCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Fuel list header -->
                <Label Text="MY FUEL LOGS" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#64748b, Dark=#8E8E8E}" />

                <!-- Empty state -->
                <VerticalStackLayout IsVisible="{Binding IsEmpty}" Spacing="10" Padding="0,30" HorizontalOptions="Center">
                    <Label Text="&#xf52f;" FontFamily="FontAwesomeSolid" FontSize="40" TextColor="{AppThemeBinding Light=#cbd5e1, Dark=#444444}" HorizontalOptions="Center" />
                    <Label Text="No fuel logs recorded yet" FontSize="14" TextColor="{AppThemeBinding Light=#94a3b8, Dark=#666666}" HorizontalOptions="Center" />
                    <Label Text='Tap "+ New" to add your first entry' FontSize="12" TextColor="{AppThemeBinding Light=#cbd5e1, Dark=#444444}" HorizontalOptions="Center" />
                </VerticalStackLayout>

                <!-- Fuel cards -->
                <CollectionView ItemsSource="{Binding Fuels}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Fuel">
                            <Border Margin="0,0,0,12" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" Padding="0" StrokeShape="RoundRectangle 14" Stroke="{AppThemeBinding Light=#e2e8f0, Dark=#2E2E2E}" StrokeThickness="1">
                                <Grid RowDefinitions="Auto, Auto">
                                    <BoxView Grid.Row="0" HeightRequest="4" BackgroundColor="#EA580C" HorizontalOptions="Fill" />
                                    <VerticalStackLayout Grid.Row="1" Padding="16" Spacing="12">

                                        <!-- Header row: date + delete -->
                                        <Grid ColumnDefinitions="*, Auto">
                                            <HorizontalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center">
                                                <Label Text="&#xf073;" FontFamily="FontAwesomeSolid" FontSize="13" TextColor="#EA580C" VerticalOptions="Center" />
                                                <Label Text="{Binding Date, StringFormat='{0:yyyy.MM.dd  HH:mm}'}" FontSize="15" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#E8E8E8}" VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                            <Border Grid.Column="1" WidthRequest="34" HeightRequest="34" StrokeShape="RoundRectangle 17" BackgroundColor="{AppThemeBinding Light=#fef2f2, Dark=#2A1A1A}" StrokeThickness="0" VerticalOptions="Center">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.DeleteFuelCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                                <Label Text="&#xf1f8;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="{AppThemeBinding Light=#DC2626, Dark=#FF6B6B}" HorizontalOptions="Center" VerticalOptions="Center" />
                                            </Border>
                                        </Grid>

                                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#f1f5f9, Dark=#2E2E2E}" />

                                        <!-- Stats row -->
                                        <Grid ColumnDefinitions="*, *, *" ColumnSpacing="8">
                                            <!-- Liters -->
                                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                                <Label Text="Liters" FontSize="10" TextColor="{AppThemeBinding Light=#94a3b8, Dark=#666666}" />
                                                <HorizontalStackLayout Spacing="5">
                                                    <Label Text="&#xf043;" FontFamily="FontAwesomeSolid" FontSize="11" TextColor="#EA580C" VerticalOptions="Center" />
                                                    <Label Text="{Binding Liters, StringFormat='{0:N1} L'}" FontSize="13" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#E8E8E8}" />
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>

                                            <!-- Cost -->
                                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                                <Label Text="Cost" FontSize="10" TextColor="{AppThemeBinding Light=#94a3b8, Dark=#666666}" />
                                                <HorizontalStackLayout Spacing="5">
                                                    <Label Text="&#xf155;" FontFamily="FontAwesomeSolid" FontSize="11" TextColor="{AppThemeBinding Light=#059669, Dark=#4ADE80}" VerticalOptions="Center" />
                                                    <Label Text="{Binding TotalCostCur}" FontSize="13" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#E8E8E8}" />
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>

                                            <!-- Plate -->
                                            <VerticalStackLayout Grid.Column="2" Spacing="2">
                                                <Label Text="Plate" FontSize="10" TextColor="{AppThemeBinding Light=#94a3b8, Dark=#666666}" />
                                                <HorizontalStackLayout Spacing="5">
                                                    <Label Text="&#xf1b9;" FontFamily="FontAwesomeSolid" FontSize="11" TextColor="#1173d4" VerticalOptions="Center" />
                                                    <Label Text="{Binding LicensePlate}" FontSize="13" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#E8E8E8}" />
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>
                                        </Grid>

                                        <!-- Station name -->
                                        <Border IsVisible="{Binding StationName, Converter={StaticResource IsNotNullConverter}}"
                                                BackgroundColor="{AppThemeBinding Light=#FFF5E5, Dark=#2A1E0D}" Padding="10,8" StrokeThickness="0" StrokeShape="RoundRectangle 8">
                                            <HorizontalStackLayout Spacing="8">
                                                <Label Text="&#xf5e4;" FontFamily="FontAwesomeSolid" FontSize="11" TextColor="#EA580C" VerticalOptions="Center" />
                                                <Label Text="{Binding StationName}" FontSize="12" TextColor="#EA580C" FontAttributes="Bold" />
                                            </HorizontalStackLayout>
                                        </Border>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Pagination -->
                <Border IsVisible="{Binding HasLoaded}" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" Padding="10,8"
                        StrokeShape="RoundRectangle 12" Stroke="{AppThemeBinding Light=#e2e8f0, Dark=#2E2E2E}" StrokeThickness="1">
                    <Grid ColumnDefinitions="Auto, *, Auto">
                        <Border Grid.Column="0" StrokeShape="RoundRectangle 10" StrokeThickness="0" Padding="12,8" BackgroundColor="{Binding CanGoBack, Converter={StaticResource BoolToColorConverter}}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding PreviousPageCommand}" />
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="&#xf053;" FontFamily="FontAwesomeSolid" FontSize="12" TextColor="{Binding CanGoBack, Converter={StaticResource BoolToTextColorConverter}}" VerticalOptions="Center" />
                                <Label Text="Prev" FontSize="13" FontAttributes="Bold" TextColor="{Binding CanGoBack, Converter={StaticResource BoolToTextColorConverter}}" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center" Spacing="0">
                            <Label Text="{Binding PageLabel}" FontSize="13" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#E8E8E8}" HorizontalOptions="Center" />
                            <Label Text="{Binding TotalCount, StringFormat='{0} total entries'}" FontSize="10" TextColor="{AppThemeBinding Light=#94a3b8, Dark=#666666}" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                        <Border Grid.Column="2" StrokeShape="RoundRectangle 10" StrokeThickness="0" Padding="12,8" BackgroundColor="{Binding CanGoForward, Converter={StaticResource BoolToColorConverter}}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding NextPageCommand}" />
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="Next" FontSize="13" FontAttributes="Bold" TextColor="{Binding CanGoForward, Converter={StaticResource BoolToTextColorConverter}}" VerticalOptions="Center" />
                                <Label Text="&#xf054;" FontFamily="FontAwesomeSolid" FontSize="12" TextColor="{Binding CanGoForward, Converter={StaticResource BoolToTextColorConverter}}" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Navigation -->
        <components:BottomNavigation Grid.Row="2" ActiveTab="Fuel" />
    </Grid>
</ContentPage>