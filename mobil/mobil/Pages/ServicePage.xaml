<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:mobil.Pages.Components"
             xmlns:vm="clr-namespace:mobil.ViewModels"
             xmlns:models="clr-namespace:mobil.Models"
             x:Class="mobil.Pages.ServicePage"
             x:DataType="vm:ServiceViewModel"
             Shell.NavBarIsVisible="False" BackgroundColor="#F6F7F8">

    <Grid RowDefinitions="Auto, *, Auto">

        <!-- Top bar -->
        <Border Grid.Row="0" Padding="15" BackgroundColor="White" StrokeShape="Rectangle" StrokeThickness="0">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <Label Grid.Column="0" Text="&#xf0ad;" FontFamily="FontAwesomeSolid" FontSize="20" TextColor="#7c3aed" VerticalOptions="Center" />
                <Label Grid.Column="1" Text="Service Requests" FontAttributes="Bold" FontSize="18" TextColor="#1a1a2e" VerticalOptions="Center" Margin="10,0,0,0" />
                <Border Grid.Column="2" StrokeShape="RoundRectangle 10" StrokeThickness="0" BackgroundColor="#7c3aed" Padding="14,8">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleNewCommand}" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="6">
                        <Label Text="&#xf067;" FontFamily="FontAwesomeSolid" FontSize="12" TextColor="White" VerticalOptions="Center" />
                        <Label Text="New" FontSize="13" FontAttributes="Bold" TextColor="White" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>
            </Grid>
        </Border>

        <!-- Scrollable content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="16">

                <!-- Loading -->
                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="#7c3aed" HeightRequest="40" />

                <!-- Error -->
                <Border IsVisible="{Binding HasError}" BackgroundColor="#FEE2E2" Stroke="#EF4444" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="12">
                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="&#xf06a;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="#DC2626" VerticalOptions="Start" />
                        <Label Grid.Column="1" Text="{Binding ErrorMessage}" TextColor="#DC2626" FontSize="13" LineBreakMode="WordWrap" />
                    </Grid>
                </Border>

                <!-- Success -->
                <Border IsVisible="{Binding HasSuccess}" BackgroundColor="#D1FAE5" Stroke="#10B981" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="12">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="&#xf058;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="#059669" VerticalOptions="Center" />
                        <Label Text="{Binding SuccessMessage}" TextColor="#059669" FontSize="13" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!-- New Service Form -->
                <Border IsVisible="{Binding IsNewService}" StrokeShape="RoundRectangle 14" Stroke="#7c3aed" StrokeThickness="1" BackgroundColor="White" Padding="16">
                    <VerticalStackLayout Spacing="14">
                        <!-- Header -->
                        <HorizontalStackLayout Spacing="8">
                            <Border WidthRequest="36" HeightRequest="36" StrokeShape="RoundRectangle 18" BackgroundColor="#f5f3ff" StrokeThickness="0">
                                <Label Text="&#xf0ad;" FontFamily="FontAwesomeSolid" FontSize="16" TextColor="#7c3aed" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Text="New Service Request" FontSize="16" FontAttributes="Bold" TextColor="#1a1a2e" VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <BoxView HeightRequest="1" Color="#f1f5f9" />

                        <!-- Title -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Title" FontSize="12" FontAttributes="Bold" TextColor="#374151" />
                            <Border StrokeShape="RoundRectangle 8" Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="12,8">
                                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                                    <Label Text="&#xf1dc;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="#9CA3AF" VerticalOptions="Center" />
                                    <Entry Grid.Column="1" Text="{Binding NewService.Title}" Placeholder="e.g. Oil change needed" BackgroundColor="Transparent" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Description -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Description (optional)" FontSize="12" FontAttributes="Bold" TextColor="#374151" />
                            <Border StrokeShape="RoundRectangle 8" Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="12,8">
                                <Editor Text="{Binding NewService.Description}" Placeholder="Describe the issue..." AutoSize="TextChanges" BackgroundColor="Transparent" MaxLength="500" MinimumHeightRequest="80" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Buttons -->
                        <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                            <Button Grid.Column="0" Text="Cancel" BackgroundColor="#E5E7EB" TextColor="#374151" FontAttributes="Bold" FontSize="14" CornerRadius="10" HeightRequest="45" Command="{Binding ToggleNewCommand}" />
                            <Button Grid.Column="1" Text="Create Request" BackgroundColor="#7c3aed" TextColor="White" FontAttributes="Bold" FontSize="14" CornerRadius="10" HeightRequest="45"
                                    Command="{Binding CreateServiceCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- List header -->
                <Label Text="MY SERVICE REQUESTS" FontSize="12" FontAttributes="Bold" TextColor="#64748b" />

                <!-- Empty state -->
                <VerticalStackLayout IsVisible="{Binding IsEmpty}" Spacing="10" Padding="0,30" HorizontalOptions="Center">
                    <Label Text="&#xf0ad;" FontFamily="FontAwesomeSolid" FontSize="40" TextColor="#cbd5e1" HorizontalOptions="Center" />
                    <Label Text="No service requests yet" FontSize="14" TextColor="#94a3b8" HorizontalOptions="Center" />
                    <Label Text='Tap "+ New" to create your first request' FontSize="12" TextColor="#cbd5e1" HorizontalOptions="Center" />
                </VerticalStackLayout>

                <!-- Service cards -->
                <CollectionView ItemsSource="{Binding Services}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Service">
                            <Border Margin="0,0,0,12" BackgroundColor="White" Padding="0" StrokeShape="RoundRectangle 14" Stroke="#e2e8f0" StrokeThickness="1">
                                <Grid RowDefinitions="Auto, Auto">
                                    <BoxView Grid.Row="0" HeightRequest="4" BackgroundColor="#7c3aed" HorizontalOptions="Fill" />
                                    <VerticalStackLayout Grid.Row="1" Padding="16" Spacing="12">

                                        <!-- Header: title + status badge -->
                                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                                <Label Text="{Binding Title}" FontSize="15" FontAttributes="Bold" TextColor="#1a1a2e" LineBreakMode="TailTruncation" />
                                                <Label Text="{Binding LicensePlate}" FontSize="11" TextColor="#64748b" />
                                            </VerticalStackLayout>
                                            <Border Grid.Column="1" StrokeShape="RoundRectangle 8" StrokeThickness="0" BackgroundColor="{Binding Status, Converter={StaticResource ServiceStatusToLightColor}}" Padding="10,5" VerticalOptions="Start">
                                                <HorizontalStackLayout Spacing="5">
                                                    <Label Text="{Binding Status, Converter={StaticResource ServiceStatusToIcon}}" FontFamily="FontAwesomeSolid" FontSize="10" TextColor="{Binding Status, Converter={StaticResource ServiceStatusToColor}}" VerticalOptions="Center" />
                                                    <Label Text="{Binding Status, Converter={StaticResource ServiceStatusToLabel}}" FontSize="11" FontAttributes="Bold" TextColor="{Binding Status, Converter={StaticResource ServiceStatusToColor}}" />
                                                </HorizontalStackLayout>
                                            </Border>
                                        </Grid>

                                        <!-- Description -->
                                        <Label Text="{Binding Description}" FontSize="12" TextColor="#64748b" MaxLines="2" LineBreakMode="TailTruncation" />

                                        <BoxView HeightRequest="1" Color="#f1f5f9" />

                                        <!-- Info row -->
                                        <Grid ColumnDefinitions="*, *" ColumnSpacing="8">
                                            <!-- Scheduled Start -->
                                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                                <Label Text="Scheduled" FontSize="10" TextColor="#94a3b8" />
                                                <HorizontalStackLayout Spacing="5">
                                                    <Label Text="&#xf073;" FontFamily="FontAwesomeSolid" FontSize="11" TextColor="#7c3aed" VerticalOptions="Center" />
                                                    <Label Text="{Binding ScheduledStart, StringFormat='{0:yyyy.MM.dd}'}" FontSize="12" FontAttributes="Bold" TextColor="#1a1a2e" />
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>

                                            <!-- Cost -->
                                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                                <Label Text="Driver Cost" FontSize="10" TextColor="#94a3b8" />
                                                <HorizontalStackLayout Spacing="5">
                                                    <Label Text="&#xf155;" FontFamily="FontAwesomeSolid" FontSize="11" TextColor="#059669" VerticalOptions="Center" />
                                                    <Label Text="{Binding DriverReportCost, StringFormat='{0:N0} Ft'}" FontSize="12" FontAttributes="Bold" TextColor="#1a1a2e" />
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>
                                        </Grid>

                                        <!-- Action buttons -->
                                        <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="8">
                                            <!-- Edit button -->
                                            <Border Grid.Column="1" StrokeShape="RoundRectangle 10" StrokeThickness="0" BackgroundColor="#f5f3ff" Padding="12,8">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.EditServiceDetailsCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                                <HorizontalStackLayout Spacing="6">
                                                    <Label Text="&#xf304;" FontFamily="FontAwesomeSolid" FontSize="12" TextColor="#7c3aed" VerticalOptions="Center" />
                                                    <Label Text="Details" FontSize="12" FontAttributes="Bold" TextColor="#7c3aed" VerticalOptions="Center" />
                                                </HorizontalStackLayout>
                                            </Border>
                                            <!-- Delete button -->
                                            <Border Grid.Column="2" WidthRequest="34" HeightRequest="34" StrokeShape="RoundRectangle 17" BackgroundColor="#fef2f2" StrokeThickness="0" VerticalOptions="Center">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.DeleteServiceCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                                <Label Text="&#xf1f8;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="#dc2626" HorizontalOptions="Center" VerticalOptions="Center" />
                                            </Border>
                                        </Grid>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Pagination -->
                <Border IsVisible="{Binding HasLoaded}" BackgroundColor="White" Padding="10,8" StrokeShape="RoundRectangle 12" Stroke="#e2e8f0" StrokeThickness="1">
                    <Grid ColumnDefinitions="Auto, *, Auto">
                        <Border Grid.Column="0" StrokeShape="RoundRectangle 10" StrokeThickness="0" Padding="12,8" BackgroundColor="{Binding CanGoBack, Converter={StaticResource BoolToColorConverter}}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding PreviousPageCommand}" />
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="&#xf053;" FontFamily="FontAwesomeSolid" FontSize="12" TextColor="{Binding CanGoBack, Converter={StaticResource BoolToTextColorConverter}}" VerticalOptions="Center" />
                                <Label Text="Prev" FontSize="13" FontAttributes="Bold" TextColor="{Binding CanGoBack, Converter={StaticResource BoolToTextColorConverter}}" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center" Spacing="0">
                            <Label Text="{Binding PageLabel}" FontSize="13" FontAttributes="Bold" TextColor="#1a1a2e" HorizontalOptions="Center" />
                            <Label Text="{Binding TotalCount, StringFormat='{0} total entries'}" FontSize="10" TextColor="#94a3b8" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                        <Border Grid.Column="2" StrokeShape="RoundRectangle 10" StrokeThickness="0" Padding="12,8" BackgroundColor="{Binding CanGoForward, Converter={StaticResource BoolToColorConverter}}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding NextPageCommand}" />
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="Next" FontSize="13" FontAttributes="Bold" TextColor="{Binding CanGoForward, Converter={StaticResource BoolToTextColorConverter}}" VerticalOptions="Center" />
                                <Label Text="&#xf054;" FontFamily="FontAwesomeSolid" FontSize="12" TextColor="{Binding CanGoForward, Converter={StaticResource BoolToTextColorConverter}}" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Navigation -->
        <components:BottomNavigation Grid.Row="2" ActiveTab="Services" />
    </Grid>
</ContentPage>