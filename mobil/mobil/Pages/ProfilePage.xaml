<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:mobil.Pages.Components"
             x:Class="mobil.Pages.ProfilePage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F6F7F8, Dark=#121212}">

    <Grid RowDefinitions="Auto, *, Auto">
        <!-- Top bar -->
        <Border Grid.Row="0" Padding="15" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" StrokeShape="Rectangle" StrokeThickness="0">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <Label Grid.Column="0" Text="&#xf007;" FontFamily="FontAwesomeSolid" FontSize="20" TextColor="#1173d4" VerticalOptions="Center" />
                <Label Grid.Column="1" Text="My Profile" FontAttributes="Bold" FontSize="18" TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#E8E8E8}" VerticalOptions="Center" Margin="10,0,0,0" />
                <Border Grid.Column="2" WidthRequest="36" HeightRequest="36" StrokeShape="RoundRectangle 18" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#fef2f2, Dark=#2A1A1A}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding LogOutCommand}" />
                    </Border.GestureRecognizers>
                    <Label Text="&#xf2f5;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="{AppThemeBinding Light=#dc2626, Dark=#FF6B6B}" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
            </Grid>
        </Border>

        <!-- Scrollable content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="20">
                <!-- Loading -->
                <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" Color="#1173d4" HeightRequest="40" />

                <!-- Error Message -->
                <Border IsVisible="{Binding HasError}" BackgroundColor="{AppThemeBinding Light=#FEE2E2, Dark=#2A1A1A}" Stroke="{AppThemeBinding Light=#EF4444, Dark=#6B2020}" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="12">
                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="&#xf06a;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="{AppThemeBinding Light=#DC2626, Dark=#FF6B6B}" VerticalOptions="Start" />
                        <Label Grid.Column="1" Text="{Binding ErrorMessage}" TextColor="{AppThemeBinding Light=#DC2626, Dark=#FF6B6B}" FontSize="13" LineBreakMode="WordWrap" />
                    </Grid>
                </Border>

                <!-- Success Message -->
                <Border IsVisible="{Binding HasSuccess}" BackgroundColor="{AppThemeBinding Light=#D1FAE5, Dark=#1A2A1E}" Stroke="{AppThemeBinding Light=#10B981, Dark=#1B5E3A}" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="12">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="&#xf058;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="{AppThemeBinding Light=#059669, Dark=#4ADE80}" VerticalOptions="Center" />
                        <Label Text="{Binding SuccessMessage}" TextColor="{AppThemeBinding Light=#059669, Dark=#4ADE80}" FontSize="13" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!-- Profile Header Card -->
                <Border StrokeShape="RoundRectangle 14" Stroke="{AppThemeBinding Light=#e2e8f0, Dark=#2E2E2E}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" Padding="20">
                    <VerticalStackLayout Spacing="14" HorizontalOptions="Center">
                        <Grid WidthRequest="80" HeightRequest="80" HorizontalOptions="Center">
                            <Border WidthRequest="80" HeightRequest="80" StrokeShape="RoundRectangle 40" StrokeThickness="0" BackgroundColor="#1173d4">
                                <Grid>
                                    <Label IsVisible="{Binding HasProfileImage, Converter={StaticResource InverseBooleanConverter}}" Text="&#xf007;" FontFamily="FontAwesomeSolid" FontSize="32" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                                    <Image IsVisible="{Binding HasProfileImage}" Source="{Binding ProfileImage}" Aspect="AspectFill" WidthRequest="80" HeightRequest="80" />
                                </Grid>
                            </Border>
                            <!-- Photo edit overlay (visible in edit mode) -->
                            <Border IsVisible="{Binding IsEditing}" WidthRequest="28" HeightRequest="28" StrokeShape="RoundRectangle 14"
                                    StrokeThickness="0" BackgroundColor="#1173d4" HorizontalOptions="End" VerticalOptions="End">
                                <Label Text="&#xf030;" FontFamily="FontAwesomeSolid" FontSize="12" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                        </Grid>
                        <!-- Preview of new photo -->
                        <Border IsVisible="{Binding HasNewPhoto}" WidthRequest="80" HeightRequest="80" StrokeShape="RoundRectangle 40" StrokeThickness="2" Stroke="#22c55e" BackgroundColor="{AppThemeBinding Light=#f0fdf4, Dark=#1A2A1E}" HorizontalOptions="Center">
                            <Image Source="{Binding EditPreviewImage}" Aspect="AspectFill" WidthRequest="80" HeightRequest="80" />
                        </Border>
                        <Label IsVisible="{Binding HasNewPhoto}" Text="New photo selected" FontSize="11" TextColor="{AppThemeBinding Light=#22c55e, Dark=#4ADE80}" HorizontalOptions="Center" />
                        <Label Text="{Binding Driver.FullName}" FontSize="22" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#E8E8E8}" HorizontalOptions="Center" />
                        <Border StrokeShape="RoundRectangle 8" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#F0F7FF, Dark=#0D2440}" Padding="10,4" HorizontalOptions="Center">
                            <Label Text="{Binding Driver.Role}" FontSize="12" FontAttributes="Bold" TextColor="#1173d4" />
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <!-- Info Card -->
                <VerticalStackLayout Spacing="12">
                    <Label Text="PERSONAL INFORMATION" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#64748b, Dark=#8E8E8E}" />
                    <Border StrokeShape="RoundRectangle 14" Stroke="{AppThemeBinding Light=#e2e8f0, Dark=#2E2E2E}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" Padding="16">
                        <VerticalStackLayout Spacing="16">
                            <!-- Email -->
                            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="12">
                                <Border WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 20" BackgroundColor="{AppThemeBinding Light=#F0F7FF, Dark=#0D2440}" StrokeThickness="0">
                                    <Label Text="&#xf0e0;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="#1173d4" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="Email" FontSize="10" TextColor="{AppThemeBinding Light=#94a3b8, Dark=#666666}" />
                                    <Label Text="{Binding Driver.Email}" FontSize="14" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#E8E8E8}" />
                                </VerticalStackLayout>
                            </Grid>

                            <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#f1f5f9, Dark=#2E2E2E}" />

                            <!-- Phone -->
                            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="12">
                                <Border WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 20" BackgroundColor="{AppThemeBinding Light=#F0F7FF, Dark=#0D2440}" StrokeThickness="0">
                                    <Label Text="&#xf095;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="#1173d4" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="Phone" FontSize="10" TextColor="{AppThemeBinding Light=#94a3b8, Dark=#666666}" />
                                    <Label Text="{Binding Driver.Phone}" FontSize="14" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#E8E8E8}" />
                                </VerticalStackLayout>
                            </Grid>

                            <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#f1f5f9, Dark=#2E2E2E}" />

                            <!-- License Number -->
                            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="12">
                                <Border WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 20" BackgroundColor="{AppThemeBinding Light=#F0F7FF, Dark=#0D2440}" StrokeThickness="0">
                                    <Label Text="&#xf2c2;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="#1173d4" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="License Number" FontSize="10" TextColor="{AppThemeBinding Light=#94a3b8, Dark=#666666}" />
                                    <Label Text="{Binding Driver.LicenseNumber}" FontSize="14" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#E8E8E8}" />
                                </VerticalStackLayout>
                            </Grid>

                            <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#f1f5f9, Dark=#2E2E2E}" />

                            <!-- License Expiry -->
                            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="12">
                                <Border WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 20" BackgroundColor="{AppThemeBinding Light=#F0F7FF, Dark=#0D2440}" StrokeThickness="0">
                                    <Label Text="&#xf073;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="#1173d4" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="License Expiry" FontSize="10" TextColor="{AppThemeBinding Light=#94a3b8, Dark=#666666}" />
                                    <Label Text="{Binding Driver.LicenseExpiryDate, StringFormat='{0:yyyy.MM.dd}'}" FontSize="14" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#E8E8E8}" />
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- Appearance / Theme Selection -->
                <VerticalStackLayout Spacing="12">
                    <Label Text="APPEARANCE" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#64748b, Dark=#8E8E8E}" />
                    <Border StrokeShape="RoundRectangle 14" Stroke="{AppThemeBinding Light=#e2e8f0, Dark=#2E2E2E}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" Padding="16">
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                            <!-- Light -->
                            <Border Grid.Column="0" StrokeShape="RoundRectangle 10" Padding="12,10">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F0F7FF, Dark=#0D2440}" />
                                        <Setter Property="Stroke" Value="{AppThemeBinding Light=#e2e8f0, Dark=#2E2E2E}" />
                                        <Setter Property="StrokeThickness" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsLightTheme}" Value="True">
                                                <Setter Property="Stroke" Value="#1173d4" />
                                                <Setter Property="StrokeThickness" Value="2" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SetThemeCommand}" CommandParameter="Light" />
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                    <Label Text="&#xf185;" FontFamily="FontAwesomeSolid" FontSize="20" HorizontalOptions="Center" TextColor="#1173d4" />
                                    <Label Text="Light" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#E8E8E8}" />
                                </VerticalStackLayout>
                            </Border>
                            <!-- Dark -->
                            <Border Grid.Column="1" StrokeShape="RoundRectangle 10" Padding="12,10">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F0F7FF, Dark=#0D2440}" />
                                        <Setter Property="Stroke" Value="{AppThemeBinding Light=#e2e8f0, Dark=#2E2E2E}" />
                                        <Setter Property="StrokeThickness" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsDarkTheme}" Value="True">
                                                <Setter Property="Stroke" Value="#1173d4" />
                                                <Setter Property="StrokeThickness" Value="2" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SetThemeCommand}" CommandParameter="Dark" />
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                    <Label Text="&#xf186;" FontFamily="FontAwesomeSolid" FontSize="20" HorizontalOptions="Center" TextColor="#1173d4" />
                                    <Label Text="Dark" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#E8E8E8}" />
                                </VerticalStackLayout>
                            </Border>
                            <!-- System -->
                            <Border Grid.Column="2" StrokeShape="RoundRectangle 10" Padding="12,10">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F0F7FF, Dark=#0D2440}" />
                                        <Setter Property="Stroke" Value="{AppThemeBinding Light=#e2e8f0, Dark=#2E2E2E}" />
                                        <Setter Property="StrokeThickness" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsSystemTheme}" Value="True">
                                                <Setter Property="Stroke" Value="#1173d4" />
                                                <Setter Property="StrokeThickness" Value="2" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SetThemeCommand}" CommandParameter="System" />
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                    <Label Text="&#xf3cd;" FontFamily="FontAwesomeSolid" FontSize="20" HorizontalOptions="Center" TextColor="#1173d4" />
                                    <Label Text="System" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#E8E8E8}" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <!-- Edit Profile Section -->
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="EDIT PROFILE" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#64748b, Dark=#8E8E8E}" VerticalOptions="Center" />
                        <Border Grid.Column="1" StrokeShape="RoundRectangle 8" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#F0F7FF, Dark=#0D2440}" Padding="10,6">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleEditCommand}" />
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="&#xf304;" FontFamily="FontAwesomeSolid" FontSize="12" TextColor="#1173d4" VerticalOptions="Center" />
                                <Label Text="Edit" FontSize="12" FontAttributes="Bold" TextColor="#1173d4" />
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>

                    <Border IsVisible="{Binding IsEditing}" StrokeShape="RoundRectangle 14" Stroke="{AppThemeBinding Light=#e2e8f0, Dark=#2E2E2E}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" Padding="16">
                        <VerticalStackLayout Spacing="16">
                            <!-- Profile Photo -->
                            <VerticalStackLayout Spacing="5">
                                <Label Text="Profile Photo" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#374151, Dark=#B0B0B0}" />
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                    <Border Grid.Column="0" StrokeShape="RoundRectangle 10" Stroke="{AppThemeBinding Light=#e2e8f0, Dark=#2E2E2E}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#F0F7FF, Dark=#0D2440}" Padding="12">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding PickPhotoCommand}" />
                                        </Border.GestureRecognizers>
                                        <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                                            <Label Text="&#xf03e;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="#1173d4" VerticalOptions="Center" />
                                            <Label Text="Gallery" FontSize="13" FontAttributes="Bold" TextColor="#1173d4" VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                    </Border>
                                    <Border Grid.Column="1" StrokeShape="RoundRectangle 10" Stroke="{AppThemeBinding Light=#e2e8f0, Dark=#2E2E2E}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#F0F7FF, Dark=#0D2440}" Padding="12">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding TakePhotoCommand}" />
                                        </Border.GestureRecognizers>
                                        <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                                            <Label Text="&#xf030;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="#1173d4" VerticalOptions="Center" />
                                            <Label Text="Camera" FontSize="13" FontAttributes="Bold" TextColor="#1173d4" VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                    </Border>
                                </Grid>
                                <!-- Delete photo button -->
                                <Border IsVisible="{Binding HasProfileImage}" StrokeShape="RoundRectangle 10" Stroke="{AppThemeBinding Light=#fecaca, Dark=#6B2020}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#fef2f2, Dark=#2A1A1A}" Padding="12">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding DeleteProfileImageCommand}" />
                                    </Border.GestureRecognizers>
                                    <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                                        <Label Text="&#xf1f8;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="{AppThemeBinding Light=#dc2626, Dark=#FF6B6B}" VerticalOptions="Center" />
                                        <Label Text="Delete Photo" FontSize="13" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#dc2626, Dark=#FF6B6B}" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </Border>
                            </VerticalStackLayout>

                            <!-- Full Name -->
                            <VerticalStackLayout Spacing="5">
                                <Label Text="Full Name" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#374151, Dark=#B0B0B0}" />
                                <Border StrokeShape="RoundRectangle 8" Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#3A3A3A}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#262626}" Padding="12,8">
                                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                                        <Label Text="&#xf007;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#666666}" VerticalOptions="Center" />
                                        <Entry Grid.Column="1" Text="{Binding EditFullName}" Placeholder="Enter full name" TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#E8E8E8}" PlaceholderColor="{AppThemeBinding Light=#9CA3AF, Dark=#666666}" BackgroundColor="Transparent" />
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>

                            <!-- Phone -->
                            <VerticalStackLayout Spacing="5">
                                <Label Text="Phone" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#374151, Dark=#B0B0B0}" />
                                <Border StrokeShape="RoundRectangle 8" Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#3A3A3A}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#262626}" Padding="12,8">
                                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                                        <Label Text="&#xf095;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#666666}" VerticalOptions="Center" />
                                        <Entry Grid.Column="1" Text="{Binding EditPhone}" Placeholder="Enter phone number" Keyboard="Telephone" TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#E8E8E8}" PlaceholderColor="{AppThemeBinding Light=#9CA3AF, Dark=#666666}" BackgroundColor="Transparent" />
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>

                            <!-- New Password -->
                            <VerticalStackLayout Spacing="5">
                                <Label Text="New Password" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#374151, Dark=#B0B0B0}" />
                                <Border StrokeShape="RoundRectangle 8" Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#3A3A3A}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#262626}" Padding="12,8">
                                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                                        <Label Text="&#xf023;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#666666}" VerticalOptions="Center" />
                                        <Entry Grid.Column="1" Text="{Binding EditPassword}" Placeholder="Leave empty to keep current" IsPassword="True" TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#E8E8E8}" PlaceholderColor="{AppThemeBinding Light=#9CA3AF, Dark=#666666}" BackgroundColor="Transparent" />
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>

                            <!-- Confirm Password -->
                            <VerticalStackLayout Spacing="5">
                                <Label Text="Confirm Password" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#374151, Dark=#B0B0B0}" />
                                <Border StrokeShape="RoundRectangle 8" Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#3A3A3A}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#262626}" Padding="12,8">
                                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                                        <Label Text="&#xf023;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#666666}" VerticalOptions="Center" />
                                        <Entry Grid.Column="1" Text="{Binding EditPasswordAgain}" Placeholder="Repeat new password" IsPassword="True" TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#E8E8E8}" PlaceholderColor="{AppThemeBinding Light=#9CA3AF, Dark=#666666}" BackgroundColor="Transparent" />
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>

                            <!-- Save / Cancel buttons -->
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Button Grid.Column="0" Text="Cancel" BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#2E2E2E}" TextColor="{AppThemeBinding Light=#374151, Dark=#B0B0B0}" FontAttributes="Bold" FontSize="14" CornerRadius="10" HeightRequest="45" Command="{Binding ToggleEditCommand}" />
                                <Button Grid.Column="1" Text="Save Changes" BackgroundColor="#1173d4" TextColor="White" FontAttributes="Bold" FontSize="14" CornerRadius="10" HeightRequest="45" Command="{Binding SaveChangesCommand}" IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- Logout Button -->
                <Border StrokeShape="RoundRectangle 12" Stroke="{AppThemeBinding Light=#fecaca, Dark=#6B2020}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#fef2f2, Dark=#2A1A1A}" Padding="14">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding LogOutCommand}" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Label Text="&#xf2f5;" FontFamily="FontAwesomeSolid" FontSize="16" TextColor="{AppThemeBinding Light=#dc2626, Dark=#FF6B6B}" VerticalOptions="Center" />
                        <Label Text="Log Out" FontSize="14" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#dc2626, Dark=#FF6B6B}" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Navigation -->
        <components:BottomNavigation Grid.Row="2" />
    </Grid>
</ContentPage>