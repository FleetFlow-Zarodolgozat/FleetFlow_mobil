<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:mobil.Pages.Components"
             x:Class="mobil.Pages.ProfilePage"
             Shell.NavBarIsVisible="False" BackgroundColor="#F6F7F8">

    <Grid RowDefinitions="Auto, *, Auto">
        <!-- Top bar -->
        <Border Grid.Row="0" Padding="15" BackgroundColor="White" StrokeShape="Rectangle" StrokeThickness="0">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <Label Grid.Column="0" Text="&#xf007;" FontFamily="FontAwesomeSolid" FontSize="20" TextColor="#1173d4" VerticalOptions="Center" />
                <Label Grid.Column="1" Text="My Profile" FontAttributes="Bold" FontSize="18" TextColor="#1a1a2e" VerticalOptions="Center" Margin="10,0,0,0" />
                <Border Grid.Column="2" WidthRequest="36" HeightRequest="36" StrokeShape="RoundRectangle 18" StrokeThickness="0" BackgroundColor="#fef2f2">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding LogOutCommand}" />
                    </Border.GestureRecognizers>
                    <Label Text="&#xf2f5;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="#dc2626" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
            </Grid>
        </Border>

        <!-- Scrollable content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="20">
                <!-- Loading -->
                <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" Color="#1173d4" HeightRequest="40" />

                <!-- Error Message -->
                <Border IsVisible="{Binding HasError}" BackgroundColor="#FEE2E2" Stroke="#EF4444" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="12">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="&#xf06a;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="#DC2626" VerticalOptions="Center" />
                        <Label Text="{Binding ErrorMessage}" TextColor="#DC2626" FontSize="13" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!-- Success Message -->
                <Border IsVisible="{Binding HasSuccess}" BackgroundColor="#D1FAE5" Stroke="#10B981" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="12">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="&#xf058;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="#059669" VerticalOptions="Center" />
                        <Label Text="{Binding SuccessMessage}" TextColor="#059669" FontSize="13" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!-- Profile Header Card -->
                <Border StrokeShape="RoundRectangle 14" Stroke="#e2e8f0" StrokeThickness="1" BackgroundColor="White" Padding="20">
                    <VerticalStackLayout Spacing="14" HorizontalOptions="Center">
                        <Border WidthRequest="80" HeightRequest="80" StrokeShape="RoundRectangle 40" StrokeThickness="0" BackgroundColor="#1173d4" HorizontalOptions="Center">
                            <Image Source="{Binding ProfileImage}" Aspect="AspectFill" WidthRequest="80" HeightRequest="80" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label Text="{Binding Driver.FullName}" FontSize="22" FontAttributes="Bold" TextColor="#1a1a2e" HorizontalOptions="Center" />
                        <Border StrokeShape="RoundRectangle 8" StrokeThickness="0" BackgroundColor="#F0F7FF" Padding="10,4" HorizontalOptions="Center">
                            <Label Text="{Binding Driver.Role}" FontSize="12" FontAttributes="Bold" TextColor="#1173d4" />
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <!-- Info Card -->
                <VerticalStackLayout Spacing="12">
                    <Label Text="PERSONAL INFORMATION" FontSize="12" FontAttributes="Bold" TextColor="#64748b" />
                    <Border StrokeShape="RoundRectangle 14" Stroke="#e2e8f0" StrokeThickness="1" BackgroundColor="White" Padding="16">
                        <VerticalStackLayout Spacing="16">
                            <!-- Email -->
                            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="12">
                                <Border WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 20" BackgroundColor="#F0F7FF" StrokeThickness="0">
                                    <Label Text="&#xf0e0;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="#1173d4" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="Email" FontSize="10" TextColor="#94a3b8" />
                                    <Label Text="{Binding Driver.Email}" FontSize="14" FontAttributes="Bold" TextColor="#1a1a2e" />
                                </VerticalStackLayout>
                            </Grid>

                            <BoxView HeightRequest="1" Color="#f1f5f9" />

                            <!-- Phone -->
                            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="12">
                                <Border WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 20" BackgroundColor="#F0F7FF" StrokeThickness="0">
                                    <Label Text="&#xf095;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="#1173d4" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="Phone" FontSize="10" TextColor="#94a3b8" />
                                    <Label Text="{Binding Driver.Phone}" FontSize="14" FontAttributes="Bold" TextColor="#1a1a2e" />
                                </VerticalStackLayout>
                            </Grid>

                            <BoxView HeightRequest="1" Color="#f1f5f9" />

                            <!-- License Number -->
                            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="12">
                                <Border WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 20" BackgroundColor="#F0F7FF" StrokeThickness="0">
                                    <Label Text="&#xf2c2;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="#1173d4" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="License Number" FontSize="10" TextColor="#94a3b8" />
                                    <Label Text="{Binding Driver.LicenseNumber}" FontSize="14" FontAttributes="Bold" TextColor="#1a1a2e" />
                                </VerticalStackLayout>
                            </Grid>

                            <BoxView HeightRequest="1" Color="#f1f5f9" />

                            <!-- License Expiry -->
                            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="12">
                                <Border WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 20" BackgroundColor="#F0F7FF" StrokeThickness="0">
                                    <Label Text="&#xf073;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="#1173d4" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="License Expiry" FontSize="10" TextColor="#94a3b8" />
                                    <Label Text="{Binding Driver.LicenseExpiryDate, StringFormat='{0:yyyy.MM.dd}'}" FontSize="14" FontAttributes="Bold" TextColor="#1a1a2e" />
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- Edit Profile Section -->
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="EDIT PROFILE" FontSize="12" FontAttributes="Bold" TextColor="#64748b" VerticalOptions="Center" />
                        <Border Grid.Column="1" StrokeShape="RoundRectangle 8" StrokeThickness="0" BackgroundColor="#F0F7FF" Padding="10,6">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleEditCommand}" />
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="&#xf304;" FontFamily="FontAwesomeSolid" FontSize="12" TextColor="#1173d4" VerticalOptions="Center" />
                                <Label Text="Edit" FontSize="12" FontAttributes="Bold" TextColor="#1173d4" />
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>

                    <Border IsVisible="{Binding IsEditing}" StrokeShape="RoundRectangle 14" Stroke="#e2e8f0" StrokeThickness="1" BackgroundColor="White" Padding="16">
                        <VerticalStackLayout Spacing="16">
                            <!-- Full Name -->
                            <VerticalStackLayout Spacing="5">
                                <Label Text="Full Name" FontSize="12" FontAttributes="Bold" TextColor="#374151" />
                                <Border StrokeShape="RoundRectangle 8" Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="12,8">
                                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                                        <Label Text="&#xf007;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="#9CA3AF" VerticalOptions="Center" />
                                        <Entry Grid.Column="1" Text="{Binding EditProfileData.FullName}" Placeholder="Enter full name" BackgroundColor="Transparent" />
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>

                            <!-- Phone -->
                            <VerticalStackLayout Spacing="5">
                                <Label Text="Phone" FontSize="12" FontAttributes="Bold" TextColor="#374151" />
                                <Border StrokeShape="RoundRectangle 8" Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="12,8">
                                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                                        <Label Text="&#xf095;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="#9CA3AF" VerticalOptions="Center" />
                                        <Entry Grid.Column="1" Text="{Binding EditProfileData.Phone}" Placeholder="Enter phone number" Keyboard="Telephone" BackgroundColor="Transparent" />
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>

                            <!-- New Password -->
                            <VerticalStackLayout Spacing="5">
                                <Label Text="New Password" FontSize="12" FontAttributes="Bold" TextColor="#374151" />
                                <Border StrokeShape="RoundRectangle 8" Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="12,8">
                                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                                        <Label Text="&#xf023;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="#9CA3AF" VerticalOptions="Center" />
                                        <Entry Grid.Column="1" Text="{Binding EditProfileData.Password}" Placeholder="Leave empty to keep current" IsPassword="True" BackgroundColor="Transparent" />
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>

                            <!-- Confirm Password -->
                            <VerticalStackLayout Spacing="5">
                                <Label Text="Confirm Password" FontSize="12" FontAttributes="Bold" TextColor="#374151" />
                                <Border StrokeShape="RoundRectangle 8" Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="12,8">
                                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                                        <Label Text="&#xf023;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="#9CA3AF" VerticalOptions="Center" />
                                        <Entry Grid.Column="1" Text="{Binding EditProfileData.PasswordAgain}" Placeholder="Repeat new password" IsPassword="True" BackgroundColor="Transparent" />
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>

                            <!-- Save / Cancel buttons -->
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Button Grid.Column="0" Text="Cancel" BackgroundColor="#E5E7EB" TextColor="#374151" FontAttributes="Bold" FontSize="14" CornerRadius="10" HeightRequest="45" Command="{Binding ToggleEditCommand}" />
                                <Button Grid.Column="1" Text="Save Changes" BackgroundColor="#1173d4" TextColor="White" FontAttributes="Bold" FontSize="14" CornerRadius="10" HeightRequest="45" Command="{Binding SaveChangesCommand}" IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- Logout Button -->
                <Border StrokeShape="RoundRectangle 12" Stroke="#fecaca" StrokeThickness="1" BackgroundColor="#fef2f2" Padding="14">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding LogOutCommand}" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Label Text="&#xf2f5;" FontFamily="FontAwesomeSolid" FontSize="16" TextColor="#dc2626" VerticalOptions="Center" />
                        <Label Text="Log Out" FontSize="14" FontAttributes="Bold" TextColor="#dc2626" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <BoxView HeightRequest="10" Color="Transparent" />
            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Navigation -->
        <components:BottomNavigation Grid.Row="2" />
    </Grid>
</ContentPage>