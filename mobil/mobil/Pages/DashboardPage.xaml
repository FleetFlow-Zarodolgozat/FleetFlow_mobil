<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="mobil.DashboardPage" Shell.NavBarIsVisible="False" BackgroundColor="#F6F7F8"
             xmlns:calendar="clr-namespace:Plugin.Maui.Calendar.Controls;assembly=Plugin.Maui.Calendar"
             xmlns:components="clr-namespace:mobil.Pages.Components">

    <Grid RowDefinitions="Auto, *, Auto">
        <!-- Top bar -->
        <Border Grid.Row="0" Padding="15" BackgroundColor="White" StrokeShape="Rectangle" StrokeThickness="0">
            <Grid ColumnDefinitions="Auto, Auto, *, Auto, Auto">
                <Label Grid.Column="1" Text="FleetFlow" FontAttributes="Bold" FontSize="18" TextColor="#1173d4" VerticalOptions="Center" Margin="10,0,0,0" />
                <Grid Grid.Column="3">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToNotificationsCommand}" />
                    </Grid.GestureRecognizers>
                    <Label Text="&#xf0f3;" FontFamily="FontAwesomeSolid" FontSize="20" VerticalOptions="Center" TextColor="#333" />
                    <Ellipse WidthRequest="8" HeightRequest="8" Fill="#ef4444" HorizontalOptions="End" VerticalOptions="Start" Margin="0,-2,-2,0" IsVisible="{Binding HaveUnreadMessage}" />
                </Grid>
                <Border Grid.Column="4" WidthRequest="35" HeightRequest="35" StrokeShape="RoundRectangle 17.5" StrokeThickness="0" BackgroundColor="#1173d4" Margin="10,0,0,0">
                    <Image Source="{Binding ProfileImage}" Aspect="AspectFill" HorizontalOptions="Center" VerticalOptions="Center" WidthRequest="35" HeightRequest="35" />
                </Border>
            </Grid>
        </Border>
        <!-- Scrollable content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="20">
                <!-- Loading indicator -->
                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="#1173d4" HeightRequest="40" />

                <!-- Header -->
                <VerticalStackLayout>
                    <Label Text="DASHBOARD" FontSize="12" FontAttributes="Bold" TextColor="#1173d4" />
                    <Label Text="{Binding WelcomeMessage}" FontSize="24" FontAttributes="Bold" TextColor="#1a1a2e" />
                </VerticalStackLayout>

                <!-- Driver Profile Card -->
                <Border StrokeShape="RoundRectangle 14" Stroke="#e2e8f0" StrokeThickness="1" BackgroundColor="White" Padding="16">
                    <VerticalStackLayout Spacing="14">
                        <!-- Driver header row -->
                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="14">
                            <Border Grid.Column="0" WidthRequest="52" HeightRequest="52" StrokeShape="RoundRectangle 26" StrokeThickness="0" BackgroundColor="#1173d4">
                                <Label Text="&#xf007;" FontFamily="FontAwesomeSolid" FontSize="22" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="{Binding Driver.FullName}" FontSize="18" FontAttributes="Bold" TextColor="#1a1a2e" />
                                <Border StrokeShape="RoundRectangle 8" StrokeThickness="0" BackgroundColor="#F0F7FF" Padding="8,3" HorizontalOptions="Start">
                                    <Label Text="{Binding Driver.Role}" FontSize="11" FontAttributes="Bold" TextColor="#1173d4" />
                                </Border>
                            </VerticalStackLayout>
                            <Border Grid.Column="2" WidthRequest="36" HeightRequest="36" StrokeShape="RoundRectangle 18" StrokeThickness="0" BackgroundColor="#F0F7FF">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding EditProfileCommand}" />
                                </Border.GestureRecognizers>
                                <Label Text="&#xf304;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="#1173d4" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#f1f5f9" />

                        <!-- Contact &amp; License info -->
                        <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto" ColumnSpacing="10" RowSpacing="12">
                            <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="8">
                                <Label Text="&#xf0e0;" FontFamily="FontAwesomeSolid" FontSize="13" TextColor="#1173d4" VerticalOptions="Center" />
                                <VerticalStackLayout>
                                    <Label Text="Email" FontSize="10" TextColor="#94a3b8" />
                                    <Label Text="{Binding Driver.Email}" FontSize="12" FontAttributes="Bold" TextColor="#1a1a2e" LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Grid.Row="0" Grid.Column="1" Spacing="8">
                                <Label Text="&#xf095;" FontFamily="FontAwesomeSolid" FontSize="13" TextColor="#1173d4" VerticalOptions="Center" />
                                <VerticalStackLayout>
                                    <Label Text="Phone" FontSize="10" TextColor="#94a3b8" />
                                    <Label Text="{Binding Driver.Phone}" FontSize="12" FontAttributes="Bold" TextColor="#1a1a2e" />
                                </VerticalStackLayout>
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Spacing="8">
                                <Label Text="&#xf2c2;" FontFamily="FontAwesomeSolid" FontSize="13" TextColor="#1173d4" VerticalOptions="Center" />
                                <VerticalStackLayout>
                                    <Label Text="License #" FontSize="10" TextColor="#94a3b8" />
                                    <Label Text="{Binding Driver.LicenseNumber}" FontSize="12" FontAttributes="Bold" TextColor="#1a1a2e" />
                                </VerticalStackLayout>
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Grid.Row="1" Grid.Column="1" Spacing="8">
                                <Label Text="&#xf073;" FontFamily="FontAwesomeSolid" FontSize="13" TextColor="#1173d4" VerticalOptions="Center" />
                                <VerticalStackLayout>
                                    <Label Text="Expires" FontSize="10" TextColor="#94a3b8" />
                                    <Label Text="{Binding Driver.LicenseExpiryDate, StringFormat='{0:yyyy.MM.dd}'}" FontSize="12" FontAttributes="Bold" TextColor="#1a1a2e" />
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Quick Actions -->
                <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                    <Border Grid.Column="0" BackgroundColor="#1173d4" Padding="14" StrokeThickness="0" StrokeShape="RoundRectangle 14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NewTripCommand}" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Border WidthRequest="36" HeightRequest="36" StrokeShape="RoundRectangle 18" BackgroundColor="#ffffff30" StrokeThickness="0">
                                <Label Text="&#xf14e;" FontFamily="FontAwesomeSolid" FontSize="16" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Text="New Trip" FontSize="14" FontAttributes="Bold" TextColor="White" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>

                    <Border Grid.Column="1" BackgroundColor="#EA580C" Padding="14" StrokeThickness="0" StrokeShape="RoundRectangle 14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NewFuelLogCommand}" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Border WidthRequest="36" HeightRequest="36" StrokeShape="RoundRectangle 18" BackgroundColor="#ffffff30" StrokeThickness="0">
                                <Label Text="&#xf52f;" FontFamily="FontAwesomeSolid" FontSize="16" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Text="New Fuel Log" FontSize="14" FontAttributes="Bold" TextColor="White" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>
                </Grid>

                <!-- Vehicle Card -->
                <VerticalStackLayout Spacing="12">
                    <Label Text="MY VEHICLE" FontSize="12" FontAttributes="Bold" TextColor="#64748b" />
                    <Border StrokeShape="RoundRectangle 14" Stroke="#e2e8f0" StrokeThickness="1" BackgroundColor="White" Padding="16">
                        <VerticalStackLayout Spacing="14">
                            <!-- Vehicle header -->
                            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">
                                <Border Grid.Column="0" WidthRequest="48" HeightRequest="48" StrokeShape="RoundRectangle 12" BackgroundColor="#F0F7FF" StrokeThickness="0">
                                    <Label Text="&#xf0d1;" FontFamily="FontAwesomeSolid" FontSize="20" TextColor="#1173d4" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{Binding Vehicle.BrandModel}" FontSize="17" FontAttributes="Bold" TextColor="#1a1a2e" />
                                    <HorizontalStackLayout Spacing="6">
                                        <Label Text="{Binding Vehicle.LicensePlate}" FontSize="12" TextColor="#64748b" FontAttributes="Bold" />
                                        <Label Text="•" FontSize="12" TextColor="#94a3b8" />
                                        <Label Text="{Binding Vehicle.Year}" FontSize="12" TextColor="#64748b" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                                <Border Grid.Column="2" StrokeShape="RoundRectangle 10" StrokeThickness="0" BackgroundColor="#ecfdf5" Padding="10,5" VerticalOptions="Center">
                                    <Label Text="{Binding Vehicle.Status}" FontSize="11" FontAttributes="Bold" TextColor="#059669" />
                                </Border>
                            </Grid>

                            <BoxView HeightRequest="1" Color="#f1f5f9" />

                            <!-- Vehicle details -->
                            <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                                <Border Grid.Column="0" BackgroundColor="#F0F7FF" Padding="12" StrokeThickness="0" StrokeShape="RoundRectangle 10">
                                    <HorizontalStackLayout Spacing="10">
                                        <Border WidthRequest="36" HeightRequest="36" StrokeShape="RoundRectangle 18" BackgroundColor="#B3D4FC" StrokeThickness="0">
                                            <Label Text="&#xf018;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="#1173d4" HorizontalOptions="Center" VerticalOptions="Center" />
                                        </Border>
                                        <VerticalStackLayout VerticalOptions="Center">
                                            <Label Text="Mileage (km)" FontSize="10" TextColor="Gray" />
                                            <Label Text="{Binding Vehicle.CurrentMileageKm, StringFormat='{0:N0}'}" FontSize="14" FontAttributes="Bold" TextColor="#1a1a2e" />
                                        </VerticalStackLayout>
                                    </HorizontalStackLayout>
                                </Border>
                                <Border Grid.Column="1" BackgroundColor="#FFF5E5" Padding="12" StrokeThickness="0" StrokeShape="RoundRectangle 10">
                                    <HorizontalStackLayout Spacing="10">
                                        <Border WidthRequest="36" HeightRequest="36" StrokeShape="RoundRectangle 18" BackgroundColor="#FEDD8E" StrokeThickness="0">
                                            <Label Text="&#xf1b9;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="#EA580C" HorizontalOptions="Center" VerticalOptions="Center" />
                                        </Border>
                                        <VerticalStackLayout VerticalOptions="Center">
                                            <Label Text="VIN" FontSize="10" TextColor="Gray" />
                                            <Label Text="{Binding Vehicle.Vin}" FontSize="11" FontAttributes="Bold" TextColor="#1a1a2e" LineBreakMode="TailTruncation" MaximumWidthRequest="100" />
                                        </VerticalStackLayout>
                                    </HorizontalStackLayout>
                                </Border>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- My Stats section -->
                <VerticalStackLayout Spacing="12">
                    <Label Text="MY STATISTICS" FontSize="12" FontAttributes="Bold" TextColor="#64748b" />
                    <Grid ColumnDefinitions="*, *, *" RowDefinitions="Auto, Auto" ColumnSpacing="10" RowSpacing="10">
                        <!-- Total Trips -->
                        <Border Grid.Row="0" Grid.Column="0" BackgroundColor="White" Padding="14" Stroke="#e2e8f0" StrokeThickness="1" StrokeShape="RoundRectangle 12">
                            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                <Border WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 20" BackgroundColor="#F0F7FF" StrokeThickness="0" HorizontalOptions="Center">
                                    <Label Text="&#xf14e;" FontFamily="FontAwesomeSolid" FontSize="16" TextColor="#1173d4" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <Label Text="{Binding Stats.TotalTrips}" FontSize="20" FontAttributes="Bold" TextColor="#1a1a2e" HorizontalOptions="Center" />
                                <Label Text="Trips" FontSize="10" TextColor="#94a3b8" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Total Fuels -->
                        <Border Grid.Row="0" Grid.Column="1" BackgroundColor="White" Padding="14" Stroke="#e2e8f0" StrokeThickness="1" StrokeShape="RoundRectangle 12">
                            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                <Border WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 20" BackgroundColor="#FFF5E5" StrokeThickness="0" HorizontalOptions="Center">
                                    <Label Text="&#xf52f;" FontFamily="FontAwesomeSolid" FontSize="16" TextColor="#ea580c" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <Label Text="{Binding Stats.TotalFuels}" FontSize="20" FontAttributes="Bold" TextColor="#1a1a2e" HorizontalOptions="Center" />
                                <Label Text="Fuelings" FontSize="10" TextColor="#94a3b8" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Total Services -->
                        <Border Grid.Row="0" Grid.Column="2" BackgroundColor="White" Padding="14" Stroke="#e2e8f0" StrokeThickness="1" StrokeShape="RoundRectangle 12">
                            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                <Border WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 20" BackgroundColor="#f5f3ff" StrokeThickness="0" HorizontalOptions="Center">
                                    <Label Text="&#xf0ad;" FontFamily="FontAwesomeSolid" FontSize="16" TextColor="#7c3aed" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <Label Text="{Binding Stats.TotalServices}" FontSize="20" FontAttributes="Bold" TextColor="#1a1a2e" HorizontalOptions="Center" />
                                <Label Text="Services" FontSize="10" TextColor="#94a3b8" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Total Distance -->
                        <Border Grid.Row="1" Grid.Column="0" BackgroundColor="White" Padding="14" Stroke="#e2e8f0" StrokeThickness="1" StrokeShape="RoundRectangle 12">
                            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                <Border WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 20" BackgroundColor="#ecfdf5" StrokeThickness="0" HorizontalOptions="Center">
                                    <Label Text="&#xf018;" FontFamily="FontAwesomeSolid" FontSize="16" TextColor="#059669" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <Label Text="{Binding Stats.TotalDistance, StringFormat='{0:N0}'}" FontSize="18" FontAttributes="Bold" TextColor="#1a1a2e" HorizontalOptions="Center" />
                                <Label Text="km" FontSize="10" TextColor="#94a3b8" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Fuel Cost -->
                        <Border Grid.Row="1" Grid.Column="1" BackgroundColor="White" Padding="14" Stroke="#e2e8f0" StrokeThickness="1" StrokeShape="RoundRectangle 12">
                            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                <Border WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 20" BackgroundColor="#fef2f2" StrokeThickness="0" HorizontalOptions="Center">
                                    <Label Text="&#xf155;" FontFamily="FontAwesomeSolid" FontSize="16" TextColor="#dc2626" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <Label Text="{Binding Stats.TotalFuelCost, StringFormat='{0:N0}'}" FontSize="15" FontAttributes="Bold" TextColor="#1a1a2e" HorizontalOptions="Center" />
                                <Label Text="Fuel Cost" FontSize="10" TextColor="#94a3b8" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Services Cost -->
                        <Border Grid.Row="1" Grid.Column="2" BackgroundColor="White" Padding="14" Stroke="#e2e8f0" StrokeThickness="1" StrokeShape="RoundRectangle 12">
                            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                <Border WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 20" BackgroundColor="#fff7ed" StrokeThickness="0" HorizontalOptions="Center">
                                    <Label Text="&#xf155;" FontFamily="FontAwesomeSolid" FontSize="16" TextColor="#ea580c" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <Label Text="{Binding Stats.TotalServicesCost, StringFormat='{0:N0}'}" FontSize="15" FontAttributes="Bold" TextColor="#1a1a2e" HorizontalOptions="Center" />
                                <Label Text="Serv. Cost" FontSize="10" TextColor="#94a3b8" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>

                <!-- Calendar section -->
                <calendar:Calendar Events="{Binding CalendarEvents}" EventIndicatorColor="Blue" DayTappedCommand="{Binding DayTappedCommand}" />
            </VerticalStackLayout>
        </ScrollView>
        <components:BottomNavigation Grid.Row="2" ActiveTab="Dashboard" />
    </Grid>
</ContentPage>