<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:mobil.Pages.Components"
             xmlns:vm="clr-namespace:mobil.ViewModels"
             xmlns:models="clr-namespace:mobil.Models"
             x:Class="mobil.Pages.TripPage"
             x:DataType="vm:TripViewModel"
             Shell.NavBarIsVisible="False" BackgroundColor="#F6F7F8">

    <Grid RowDefinitions="Auto, *, Auto">

        <!-- Top bar -->
        <Border Grid.Row="0" Padding="15" BackgroundColor="White" StrokeShape="Rectangle" StrokeThickness="0">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <Label Grid.Column="0" Text="&#xf14e;" FontFamily="FontAwesomeSolid" FontSize="20" TextColor="#1173d4" VerticalOptions="Center" />
                <Label Grid.Column="1" Text="Trips" FontAttributes="Bold" FontSize="18" TextColor="#1a1a2e" VerticalOptions="Center" Margin="10,0,0,0" />
                <Border Grid.Column="2" StrokeShape="RoundRectangle 10" StrokeThickness="0" BackgroundColor="#1173d4" Padding="14,8">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleNewCommand}" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="6">
                        <Label Text="&#xf067;" FontFamily="FontAwesomeSolid" FontSize="12" TextColor="White" VerticalOptions="Center" />
                        <Label Text="New" FontSize="13" FontAttributes="Bold" TextColor="White" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>
            </Grid>
        </Border>

        <!-- Scrollable content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="16">

                <!-- Loading -->
                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="#1173d4" HeightRequest="40" />

                <!-- Error -->
                <Border IsVisible="{Binding HasError}" BackgroundColor="#FEE2E2" Stroke="#EF4444" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="12">
                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="&#xf06a;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="#DC2626" VerticalOptions="Start" />
                        <Label Grid.Column="1" Text="{Binding ErrorMessage}" TextColor="#DC2626" FontSize="13" LineBreakMode="WordWrap" />
                    </Grid>
                </Border>

                <!-- Success -->
                <Border IsVisible="{Binding HasSuccess}" BackgroundColor="#D1FAE5" Stroke="#10B981" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="12">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="&#xf058;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="#059669" VerticalOptions="Center" />
                        <Label Text="{Binding SuccessMessage}" TextColor="#059669" FontSize="13" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!-- New Trip Form -->
                <Border IsVisible="{Binding IsNewTrip}" StrokeShape="RoundRectangle 14" Stroke="#1173d4" StrokeThickness="1" BackgroundColor="White" Padding="16">
                    <VerticalStackLayout Spacing="14">
                        <!-- Header -->
                        <HorizontalStackLayout Spacing="8">
                            <Border WidthRequest="36" HeightRequest="36" StrokeShape="RoundRectangle 18" BackgroundColor="#F0F7FF" StrokeThickness="0">
                                <Label Text="&#xf14e;" FontFamily="FontAwesomeSolid" FontSize="16" TextColor="#1173d4" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Text="New Trip" FontSize="16" FontAttributes="Bold" TextColor="#1a1a2e" VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <BoxView HeightRequest="1" Color="#f1f5f9" />

                        <!-- Start Time -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Start" FontSize="12" FontAttributes="Bold" TextColor="#374151" />
                            <Grid ColumnDefinitions="*, *" ColumnSpacing="8">
                                <Border Grid.Column="0" StrokeShape="RoundRectangle 8" Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="10,4">
                                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="6">
                                        <Label Text="&#xf073;" FontFamily="FontAwesomeSolid" FontSize="13" TextColor="#9CA3AF" VerticalOptions="Center" />
                                        <DatePicker Grid.Column="1" Date="{Binding NewStartDate}" Format="yyyy.MM.dd" TextColor="#1a1a2e" BackgroundColor="Transparent" FontSize="13" />
                                    </Grid>
                                </Border>
                                <Border Grid.Column="1" StrokeShape="RoundRectangle 8" Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="10,4">
                                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="6">
                                        <Label Text="&#xf017;" FontFamily="FontAwesomeSolid" FontSize="13" TextColor="#9CA3AF" VerticalOptions="Center" />
                                        <TimePicker Grid.Column="1" Time="{Binding NewStartTime}" TextColor="#1a1a2e" BackgroundColor="Transparent" FontSize="13" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </VerticalStackLayout>

                        <!-- End Time -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="End" FontSize="12" FontAttributes="Bold" TextColor="#374151" />
                            <Grid ColumnDefinitions="*, *" ColumnSpacing="8">
                                <Border Grid.Column="0" StrokeShape="RoundRectangle 8" Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="10,4">
                                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="6">
                                        <Label Text="&#xf073;" FontFamily="FontAwesomeSolid" FontSize="13" TextColor="#9CA3AF" VerticalOptions="Center" />
                                        <DatePicker Grid.Column="1" Date="{Binding NewEndDate}" Format="yyyy.MM.dd" TextColor="#1a1a2e" BackgroundColor="Transparent" FontSize="13" />
                                    </Grid>
                                </Border>
                                <Border Grid.Column="1" StrokeShape="RoundRectangle 8" Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="10,4">
                                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="6">
                                        <Label Text="&#xf017;" FontFamily="FontAwesomeSolid" FontSize="13" TextColor="#9CA3AF" VerticalOptions="Center" />
                                        <TimePicker Grid.Column="1" Time="{Binding NewEndTime}" TextColor="#1a1a2e" BackgroundColor="Transparent" FontSize="13" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </VerticalStackLayout>

                        <!-- Start Location -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Start Location" FontSize="12" FontAttributes="Bold" TextColor="#374151" />
                            <Border StrokeShape="RoundRectangle 8" Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="12,8">
                                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                                    <Label Text="&#xf3c5;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="#9CA3AF" VerticalOptions="Center" />
                                    <Entry Grid.Column="1" Text="{Binding NewTrip.StartLocation}" Placeholder="e.g. Budapest" BackgroundColor="Transparent" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- End Location -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="End Location" FontSize="12" FontAttributes="Bold" TextColor="#374151" />
                            <Border StrokeShape="RoundRectangle 8" Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="12,8">
                                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                                    <Label Text="&#xf3c5;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="#9CA3AF" VerticalOptions="Center" />
                                    <Entry Grid.Column="1" Text="{Binding NewTrip.EndLocation}" Placeholder="e.g. Győr" BackgroundColor="Transparent" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Distance + Odometers -->
                        <Grid ColumnDefinitions="*, *, *" ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0" Spacing="5">
                                <Label Text="Distance (km)" FontSize="11" FontAttributes="Bold" TextColor="#374151" />
                                <Border StrokeShape="RoundRectangle 8" Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="10,8">
                                    <Entry Text="{Binding NewTrip.DistanceKm}" Keyboard="Numeric" Placeholder="0" BackgroundColor="Transparent" FontSize="13" />
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="5">
                                <Label Text="Start Odo." FontSize="11" FontAttributes="Bold" TextColor="#374151" />
                                <Border StrokeShape="RoundRectangle 8" Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="10,8">
                                    <Entry Text="{Binding NewTrip.StartOdometerKm}" Keyboard="Numeric" Placeholder="0" BackgroundColor="Transparent" FontSize="13" />
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="2" Spacing="5">
                                <Label Text="End Odo." FontSize="11" FontAttributes="Bold" TextColor="#374151" />
                                <Border StrokeShape="RoundRectangle 8" Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="10,8">
                                    <Entry Text="{Binding NewTrip.EndOdometerKm}" Keyboard="Numeric" Placeholder="0" BackgroundColor="Transparent" FontSize="13" />
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Notes -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Notes (optional)" FontSize="12" FontAttributes="Bold" TextColor="#374151" />
                            <Border StrokeShape="RoundRectangle 8" Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="12,8">
                                <Editor Text="{Binding NewTrip.Notes}" Placeholder="Any notes..." AutoSize="TextChanges" BackgroundColor="Transparent" MaxLength="300" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Buttons -->
                        <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                            <Button Grid.Column="0" Text="Cancel" BackgroundColor="#E5E7EB" TextColor="#374151" FontAttributes="Bold" FontSize="14" CornerRadius="10" HeightRequest="45" Command="{Binding ToggleNewCommand}" />
                            <Button Grid.Column="1" Text="Create Trip" BackgroundColor="#1173d4" TextColor="White" FontAttributes="Bold" FontSize="14" CornerRadius="10" HeightRequest="45"
                                    Command="{Binding CreateTripCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Trips list header -->
                <Label Text="MY TRIPS" FontSize="12" FontAttributes="Bold" TextColor="#64748b" />

                <!-- Empty state -->
                <VerticalStackLayout IsVisible="{Binding IsEmpty}" Spacing="10" Padding="0,30" HorizontalOptions="Center">
                    <Label Text="&#xf14e;" FontFamily="FontAwesomeSolid" FontSize="40" TextColor="#cbd5e1" HorizontalOptions="Center" />
                    <Label Text="No trips recorded yet" FontSize="14" TextColor="#94a3b8" HorizontalOptions="Center" />
                    <Label Text='Tap "+ New" to add your first trip' FontSize="12" TextColor="#cbd5e1" HorizontalOptions="Center" />
                </VerticalStackLayout>

                <!-- Trip cards -->
                <CollectionView ItemsSource="{Binding Trips}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Trip">
                            <Border Margin="0,0,0,12" BackgroundColor="White" Padding="0" StrokeShape="RoundRectangle 14" Stroke="#e2e8f0" StrokeThickness="1">
                                <Grid RowDefinitions="Auto, Auto">
                                    <!-- Colored top strip based on route -->
                                    <BoxView Grid.Row="0" HeightRequest="4" BackgroundColor="#1173d4" HorizontalOptions="Fill" />
                                    <VerticalStackLayout Grid.Row="1" Padding="16" Spacing="12">
                                        <!-- Route row -->
                                        <Grid ColumnDefinitions="*, Auto">
                                            <HorizontalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center">
                                                <Label Text="&#xf3c5;" FontFamily="FontAwesomeSolid" FontSize="13" TextColor="#1173d4" VerticalOptions="Center" />
                                                <Label Text="{Binding StartLocation}" FontSize="14" FontAttributes="Bold" TextColor="#1a1a2e" VerticalOptions="Center" />
                                                <Label Text="&#xf178;" FontFamily="FontAwesomeSolid" FontSize="12" TextColor="#94a3b8" VerticalOptions="Center" />
                                                <Label Text="{Binding EndLocation}" FontSize="14" FontAttributes="Bold" TextColor="#1a1a2e" VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                            <!-- Delete button -->
                                            <Border Grid.Column="1" WidthRequest="34" HeightRequest="34" StrokeShape="RoundRectangle 17" BackgroundColor="#fef2f2" StrokeThickness="0" VerticalOptions="Center">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.DeleteTripCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                                <Label Text="&#xf1f8;" FontFamily="FontAwesomeSolid" FontSize="14" TextColor="#dc2626" HorizontalOptions="Center" VerticalOptions="Center" />
                                            </Border>
                                        </Grid>
                                        <BoxView HeightRequest="1" Color="#f1f5f9" />
                                        <!-- Stats row -->
                                        <Grid ColumnDefinitions="*, *, *" ColumnSpacing="8">
                                            <!-- Date -->
                                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                                <Label Text="Date" FontSize="10" TextColor="#94a3b8" />
                                                <HorizontalStackLayout Spacing="5">
                                                    <Label Text="&#xf073;" FontFamily="FontAwesomeSolid" FontSize="11" TextColor="#1173d4" VerticalOptions="Center" />
                                                    <Label Text="{Binding StartTime, StringFormat='{0:yyyy.MM.dd}'}" FontSize="12" FontAttributes="Bold" TextColor="#1a1a2e" />
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>

                                            <!-- Distance -->
                                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                                <Label Text="Distance" FontSize="10" TextColor="#94a3b8" />
                                                <HorizontalStackLayout Spacing="5">
                                                    <Label Text="&#xf018;" FontFamily="FontAwesomeSolid" FontSize="11" TextColor="#059669" VerticalOptions="Center" />
                                                    <Label Text="{Binding DistanceKm, StringFormat='{0:N1} km'}" FontSize="12" FontAttributes="Bold" TextColor="#1a1a2e" />
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>

                                            <!-- License Plate -->
                                            <VerticalStackLayout Grid.Column="2" Spacing="2">
                                                <Label Text="Plate" FontSize="10" TextColor="#94a3b8" />
                                                <HorizontalStackLayout Spacing="5">
                                                    <Label Text="&#xf1b9;" FontFamily="FontAwesomeSolid" FontSize="11" TextColor="#EA580C" VerticalOptions="Center" />
                                                    <Label Text="{Binding LicensePlate}" FontSize="12" FontAttributes="Bold" TextColor="#1a1a2e" />
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>
                                        </Grid>

                                        <!-- Notes (only if present) -->
                                        <Border IsVisible="{Binding Notes, Converter={StaticResource IsNotNullConverter}}" BackgroundColor="#F8FAFC" Padding="10,8" StrokeThickness="0" StrokeShape="RoundRectangle 8">
                                            <HorizontalStackLayout Spacing="8">
                                                <Label Text="&#xf249;" FontFamily="FontAwesomeSolid" FontSize="11" TextColor="#64748b" VerticalOptions="Start" />
                                                <Label Text="{Binding Notes}" FontSize="12" TextColor="#64748b" LineBreakMode="WordWrap" />
                                            </HorizontalStackLayout>
                                        </Border>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Pagination -->
                <Border IsVisible="{Binding HasLoaded}" BackgroundColor="White" Padding="10,8" StrokeShape="RoundRectangle 12" Stroke="#e2e8f0" StrokeThickness="1">
                    <Grid ColumnDefinitions="Auto, *, Auto">
                        <!-- Previous -->
                        <Border Grid.Column="0" StrokeShape="RoundRectangle 10" StrokeThickness="0" Padding="12,8" BackgroundColor="{Binding CanGoBack, Converter={StaticResource BoolToColorConverter}}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding PreviousPageCommand}" />
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="&#xf053;" FontFamily="FontAwesomeSolid" FontSize="12" TextColor="{Binding CanGoBack, Converter={StaticResource BoolToTextColorConverter}}" VerticalOptions="Center" />
                                <Label Text="Prev" FontSize="13" FontAttributes="Bold" TextColor="{Binding CanGoBack, Converter={StaticResource BoolToTextColorConverter}}" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Page info -->
                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center" Spacing="0">
                            <Label Text="{Binding PageLabel}" FontSize="13" FontAttributes="Bold" TextColor="#1a1a2e" HorizontalOptions="Center" />
                            <Label Text="{Binding TotalCount, StringFormat='{0} total trips'}" FontSize="10" TextColor="#94a3b8" HorizontalOptions="Center" />
                        </VerticalStackLayout>

                        <!-- Next -->
                        <Border Grid.Column="2" StrokeShape="RoundRectangle 10" StrokeThickness="0" Padding="12,8" BackgroundColor="{Binding CanGoForward, Converter={StaticResource BoolToColorConverter}}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding NextPageCommand}" />
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="Next" FontSize="13" FontAttributes="Bold" TextColor="{Binding CanGoForward, Converter={StaticResource BoolToTextColorConverter}}" VerticalOptions="Center" />
                                <Label Text="&#xf054;" FontFamily="FontAwesomeSolid" FontSize="12" TextColor="{Binding CanGoForward, Converter={StaticResource BoolToTextColorConverter}}" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Navigation -->
        <components:BottomNavigation Grid.Row="2" ActiveTab="Trips" />
    </Grid>
</ContentPage>