<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:mobil"
             xmlns:converters="clr-namespace:mobil.Converters"
             x:Class="mobil.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
            <converters:PasswordIconConverter x:Key="PasswordIconConverter" />
            <converters:IsNotNullConverter x:Key="IsNotNullConverter" />
            <converters:IsNotZeroConverter x:Key="IsNotZeroConverter" />
            <converters:BoolToColorConverter x:Key="BoolToColorConverter" />
            <converters:BoolToTextColorConverter x:Key="BoolToTextColorConverter" />
            <converters:NotificationTypeToColorConverter x:Key="NotifTypeToColor" />
            <converters:NotificationTypeToLightColorConverter x:Key="NotifTypeToLightColor" />
            <converters:NotificationTypeToIconConverter x:Key="NotifTypeToIcon" />
            <converters:NotificationTypeToLabelConverter x:Key="NotifTypeToLabel" />
            <converters:TabColorConverter x:Key="TabColor" />
            <converters:TabFontAttributesConverter x:Key="TabFont" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
